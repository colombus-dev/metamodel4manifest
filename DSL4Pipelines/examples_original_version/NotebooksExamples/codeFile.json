{
  "codes": [
    {
      "instruction": {
        "code": "import pandas as pd",
        "cell_id": "cell_1",
        "ligne": 1
      }
    },
    {
      "instruction": {
        "code": "import numpy as np",
        "cell_id": "cell_1",
        "ligne": 2
      }
    },
    {
      "instruction": {
        "code": "import matplotlib.pyplot as plt",
        "cell_id": "cell_1",
        "ligne": 3
      }
    },
    {
      "instruction": {
        "code": "import seaborn as sns",
        "cell_id": "cell_1",
        "ligne": 4
      }
    },
    {
      "instruction": {
        "code": "from sklearn.model_selection import train_test_split",
        "cell_id": "cell_1",
        "ligne": 5
      }
    },
    {
      "instruction": {
        "code": "from sklearn.tree import DecisionTreeClassifier",
        "cell_id": "cell_1",
        "ligne": 6
      }
    },
    {
      "instruction": {
        "code": "from sklearn.metrics import accuracy_score, classification_report, confusion_matrix",
        "cell_id": "cell_1",
        "ligne": 7
      }
    },
    {
      "instruction": {
        "code": "from sklearn.datasets import load_iris",
        "cell_id": "cell_1",
        "ligne": 8
      }
    },
    {
      "instruction": {
        "code": "iris = load_iris()",
        "cell_id": "cell_1",
        "ligne": 9
      }
    },
    {
      "instruction": {
        "code": "df = pd.DataFrame(data=np.c_[iris['data'], iris['target']],",
        "cell_id": "cell_1",
        "ligne": 10
      }
    },
    {
      "instruction": {
        "code": "                  columns=iris['feature_names'] + ['target'])",
        "cell_id": "cell_1",
        "ligne": 11
      }
    },
    {
      "instruction": {
        "code": "print(df.head())",
        "cell_id": "cell_1",
        "ligne": 12
      }
    },
    {
      "instruction": {
        "code": "df.columns = ['sepal_length', 'sepal_width', 'petal_length', 'petal_width', 'species']",
        "cell_id": "cell_2",
        "ligne": 1
      }
    },
    {
      "instruction": {
        "code": "sns.pairplot(df, hue='species')",
        "cell_id": "cell_2",
        "ligne": 2
      }
    },
    {
      "instruction": {
        "code": "plt.show()",
        "cell_id": "cell_2",
        "ligne": 3
      }
    },
    {
      "instruction": {
        "code": "plt.figure(figsize=(8, 6))",
        "cell_id": "cell_2",
        "ligne": 4
      }
    },
    {
      "instruction": {
        "code": "sns.histplot(data=df, x='petal_length', hue='species', multiple='stack')",
        "cell_id": "cell_2",
        "ligne": 5
      }
    },
    {
      "instruction": {
        "code": "plt.title('Distribution de la longueur des pétales')",
        "cell_id": "cell_2",
        "ligne": 6
      }
    },
    {
      "instruction": {
        "code": "plt.show()",
        "cell_id": "cell_2",
        "ligne": 7
      }
    },
    {
      "instruction": {
        "code": "X = df.drop('species', axis=1)",
        "cell_id": "cell_2",
        "ligne": 8
      }
    },
    {
      "instruction": {
        "code": "y = df['species']",
        "cell_id": "cell_2",
        "ligne": 9
      }
    },
    {
      "instruction": {
        "code": "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)",
        "cell_id": "cell_2",
        "ligne": 10
      }
    },
    {
      "instruction": {
        "code": "model = DecisionTreeClassifier(random_state=42)",
        "cell_id": "cell_3",
        "ligne": 1
      }
    },
    {
      "instruction": {
        "code": "model.fit(X_train, y_train)",
        "cell_id": "cell_3",
        "ligne": 2
      }
    },
    {
      "instruction": {
        "code": "predictions = model.predict(X_test)",
        "cell_id": "cell_4",
        "ligne": 1
      }
    },
    {
      "instruction": {
        "code": "accuracy = accuracy_score(y_test, predictions)",
        "cell_id": "cell_4",
        "ligne": 2
      }
    },
    {
      "instruction": {
        "code": "print(f'Accuracy du modèle : {accuracy:.2f}')",
        "cell_id": "cell_4",
        "ligne": 3
      }
    },
    {
      "instruction": {
        "code": "print('\\nRapport de classification :')",
        "cell_id": "cell_4",
        "ligne": 4
      }
    },
    {
      "instruction": {
        "code": "print(classification_report(y_test, predictions))",
        "cell_id": "cell_4",
        "ligne": 5
      }
    },
    {
      "instruction": {
        "code": "cm = confusion_matrix(y_test, predictions)",
        "cell_id": "cell_4",
        "ligne": 6
      }
    },
    {
      "instruction": {
        "code": "plt.figure(figsize=(8, 6))",
        "cell_id": "cell_4",
        "ligne": 7
      }
    },
    {
      "instruction": {
        "code": "sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',",
        "cell_id": "cell_4",
        "ligne": 8
      }
    },
    {
      "instruction": {
        "code": "            xticklabels=iris.target_names, yticklabels=iris.target_names)",
        "cell_id": "cell_4",
        "ligne": 9
      }
    },
    {
      "instruction": {
        "code": "plt.xlabel('Prédiction')",
        "cell_id": "cell_4",
        "ligne": 10
      }
    },
    {
      "instruction": {
        "code": "plt.ylabel('Valeur réelle')",
        "cell_id": "cell_4",
        "ligne": 11
      }
    },
    {
      "instruction": {
        "code": "plt.title('Matrice de Confusion')",
        "cell_id": "cell_4",
        "ligne": 12
      }
    },
    {
      "instruction": {
        "code": "plt.show()",
        "cell_id": "cell_4",
        "ligne": 13
      }
    }
  ]
}